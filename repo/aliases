# make directory and change into it
function mkcd() { mkdir -p "$1" && cd "$1"; }

# checkout code in the right directory and change to directory
function gitcd() {
	regex="(git@|https:\/\/)(.*)[:\/](.*)\/(.*).git"
	if [[ $1 =~ $regex ]]; then
		host=${BASH_REMATCH[2]}
		user=${BASH_REMATCH[3]}
		repo=${BASH_REMATCH[4]}
		root=$GITROOT || $PWD
		dir="$root/$host/$user"
		mkdir -vp $dir
		cd $dir
		if [ ! -d "$repo" ]; then
			echo "New git repo"
			git clone $1
		fi
		cd $repo
	fi
}

# launch docker container in the current directory
function poddy() {
  podman run -it --name poddy_$1 -v $PWD:$PWD -w $PWD $1 /bin/bash
  podman rm -if poddy_$1
}

# directory listing shortcut
function la() {
  echo "ls -la"
  ls -la
}
